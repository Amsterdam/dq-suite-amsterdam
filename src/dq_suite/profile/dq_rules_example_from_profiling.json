                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeOfType",
                    "parameters": {
                        "column": "trip_distance",
                        "type_": "Numeric"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToNotBeNull",
                    "parameters": {
                        "column": "fare_amount"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeBetween",
                    "parameters": {
                        "column": "fare_amount",
                        "min_value": 0.0,
                        "max_value": 88.0
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeOfType",
                    "parameters": {
                        "column": "fare_amount",
                        "type_": "Numeric"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToNotBeNull",
                    "parameters": {
                        "column": "pickup_zip"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeBetween",
                    "parameters": {
                        "column": "pickup_zip",
                        "min_value": 10001,
                        "max_value": 11422
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeOfType",
                    "parameters": {
                        "column": "pickup_zip",
                        "type_": "Numeric"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToNotBeNull",
                    "parameters": {
                        "column": "dropoff_zip"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeBetween",
                    "parameters": {
