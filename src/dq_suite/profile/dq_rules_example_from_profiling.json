{
    "dataset": {
        "name": "Taxiritten",
        "layer": "<LAYER TO BE FILLED IN>"
    },
    "tables": [
        {
            "unique_identifier": "<TO BE FILLED IN>",
            "table_name": "nyc_taxi",
            "rules": [
                {
                    "rule_name": "ExpectCompoundColumnsToBeUnique",
                    "parameters": {
                        "column_list": [
                            "<COLUMNS TO BE FILLED IN AS A LIST>"
                        ]
                    }
                },
                {
                    "rule_name": "ExpectTableRowCountToBeBetween",
                    "parameters": {
                        "min_value": "<TO BE FILLED IN AS INT>",
                        "max_value": "<TO BE FILLED IN AS INT>"
                    }
                },
                {
                    "rule_name": "ExpectTableColumnsToMatchSet",
                    "parameters": {
                        "column_set": "[<COLUMNS TO BE FILLED IN>]",
                        "exact_match": true
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToMatchRegex",
                    "parameters": {
                        "column": "tpep_pickup_datetime",
                        "regex": "^(\\d{4})(0[1-9]|1[0-2])(0[1-9]|[12]\\d|30|31)"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeBetween",
                    "parameters": {
                        "column": "tpep_pickup_datetime",
                        "min_value": "2016-02-01 06:43:24",
                        "max_value": "2016-02-29 22:19:22"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeOfType",
                    "parameters": {
                        "column": "tpep_pickup_datetime",
                        "type_": "DateTime"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToMatchRegex",
                    "parameters": {
                        "column": "tpep_dropoff_datetime",
                        "regex": "^(\\d{4})(0[1-9]|1[0-2])(0[1-9]|[12]\\d|30|31)"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeBetween",
                    "parameters": {
                        "column": "tpep_dropoff_datetime",
                        "min_value": "2016-02-01 06:43:24",
                        "max_value": "2016-02-29 20:32:44"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeOfType",
                    "parameters": {
                        "column": "tpep_dropoff_datetime",
                        "type_": "DateTime"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToNotBeNull",
                    "parameters": {
                        "column": "trip_distance"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeBetween",
                    "parameters": {
