                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeOfType",
                    "parameters": {
                        "column": "dropoff_zip",
                        "type_": "Numeric"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeUnique",
                    "parameters": {
                        "column": "id"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToNotBeNull",
                    "parameters": {
                        "column": "id"
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeBetween",
                    "parameters": {
                        "column": "id",
                        "min_value": 0,
                        "max_value": 999
                    }
                },
                {
                    "rule_name": "ExpectColumnValuesToBeOfType",
                    "parameters": {
                        "column": "id",
                        "type_": "Numeric"
                    }
                },
                {
                    "rule_name": "ExpectColumnPairValuesAToBeGreaterThanB",
                    "parameters": {
                        "column_A": "tpep_dropoff_datetime",
                        "column_B": "tpep_pickup_datetime",
                        "or_equal": false
                    }
                }
            ]
        }
