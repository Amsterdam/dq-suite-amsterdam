{
    "team": {
        "teamid": "dpd1",
        "teamname": "DMT",
        "teamdescription": "Data Management Team"
    },
    "dataset": {
        "name": "Customer",
        "layer": "goud"
    },
    "tables": [
        {
            "unique_identifier": "id",
            "table_name": "customer",
            "rules": [ 
                {
                    "rule_name": "ExpectColumnValuesToNotBeNull",
                    "severity" : "warning",
                    "parameters": {
                            "column": "id"
                        }
                },
                 {
                    "rule_name": "ExpectColumnValuesToBeUnique",
                    "parameters": {
                        "column": "id"
                    },
                    "severity": "warning",
                    "norm": null
                },
                {
                    "rule_name": "ExpectCompoundColumnsToBeUnique",
                    "parameters": {
                        "column_list": [
                            "id","firstName", "middleName", "lastName"   
                      ]
                    },
                    "severity": "warning",
                    "norm": null
                }, 
                {
                    "rule_name": "ExpectTableColumnsToMatchSet",
                    "parameters": {
                        "column_set": [
                            "id",
                            "firstName",
                            "middleName",
                            "lastName",
                            "gender",
                            "birthDate",
                            "ssn"          
                        ],
                        "exact_match": true
                    },
                    "severity": "warning",
                    "norm": null
                },
                 {
                    "rule_name": "ExpectColumnValuesToBeOfType",
                    "parameters": {
                        "column": "id",
                        "type_": "IntegerType"
                    },
                    "severity": "warning",
                    "norm": null
                },
                 {
                    "rule_name": "ExpectColumnValuesToMatchRegex",
                    "parameters": {
                        "column": "birthDate",
                        "regex": "^(\\d{4})(0[1-9]|1[0-2])(0[1-9]|[12]\\d|30|31)"
                    },
                    "severity": "warning",
                    "norm": null
                },
               
                 {
                    "rule_name": "ExpectColumnValuesToBeBetween",
                    "parameters": {
                        "column": "id",
                        "min_value": 1,
                        "max_value": 1000
                    },
                    "severity": "warning",
                    "norm": null
                },
                {
                    "rule_name": "ExpectTableRowCountToBeBetween",
                    "parameters": {
                        "min_value": 0,
                        "max_value": 999
                    },
                    "severity": "warning",
                    "norm": null
                }
                
            ]
        }
    ]
}